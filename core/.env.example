# Copy this file to `.env` and fill in real values.
# `.env` is gitignored so secrets never leave your machine.

# --- PostgreSQL (used by docker-compose.yml AND every Spring Boot service) ---
DB_USERNAME=lynxteam2
DB_PASSWORD=lynxteam2
DB_NAME=brokerplatformdb

# --- JWT signing key for UserService ---
# Must be at least 256 bits (32 chars) for HS256. Generate one with:
#   openssl rand -base64 48
JWT_SECRET=replace-me-with-a-long-random-string-at-least-32-chars

# --- SMTP credentials for password reset / verification emails ---
# For Gmail, generate an App Password at https://myaccount.google.com/apppasswords
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
